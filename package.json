{
  "name": "tante-piav",
  "version": "0.1.0",
  "private": true,
  "description": "Statische medizinische Gedankenstütze für Differentialdiagnosen anhand des Akronyms TANTE PIAV.",
  "type": "module",
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "test": "vitest run",
    "validate:data": "vitest run src/data/contentIntegrity.test.ts",
    "check": "npm run lint && npm run test && npm run build",
    "audit": "npm audit --audit-level=high"
  },
  "dependencies": {
    "fuse.js": "^7.4.2",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.14",
    "@types/react-dom": "^18.3.2",
    "@vitejs/plugin-react": "^6.0.3",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^16.5.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.46.2",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  }
